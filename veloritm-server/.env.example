# Copy to `.env` and adjust. docker-compose reads this file automatically.

# --- PostgreSQL ---
POSTGRES_DB=veloritm
POSTGRES_USER=veloritm
POSTGRES_PASSWORD=veloritm

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Production app config (used by the `prod` Spring profile, not docker-compose) ---
# DB_URL=jdbc:postgresql://db:5432/veloritm
# DB_USERNAME=veloritm
# DB_PASSWORD=change-me
# APP_CORS_ALLOWED_ORIGINS=https://veloritm.ua
